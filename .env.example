PORT=3001

# Comma-separated list of allowed Google emails
ALLOWED_USERS=user@gmail.com

# Google OAuth credentials
CLIENT_ID=your-google-client-id.apps.googleusercontent.com
CLIENT_SECRET=your-google-client-secret

# Strong random secret for session signing
SESSION_SECRET=replace-with-a-long-random-secret

# Optional: long-lived session duration in days (default 180)
SESSION_MAX_AGE_DAYS=180

# Optional: force absolute callback URL behind proxies/tunnels
# BASE_URL=https://your-domain.example

# Redicrect URI https://YOUR_DOMAIN/auth/callback